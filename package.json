{
  "name": "camms",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build && tsx scripts/check-bundle-budget.ts",
    "start": "next start",
    "lint": "eslint",
    "check": "npm run verify-env && npm test && npm run lint && npm run build",
    "test": "tsx scripts/run-tests.ts",
    "test:coverage": "tsx scripts/run-tests.ts --coverage",
    "test:smoke": "playwright test --project=smoke",
    "test:e2e": "playwright test --project=chromium",
    "test:all": "npm run check && npm run test:smoke",
    "verify-env": "tsx scripts/verify-env.ts",
    "audit:release": "npm audit --omit=dev --audit-level=high",
    "mcp": "tsx scripts/mcp-server.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "radix-ui": "^1.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.80.0",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "glob": "^13.0.6",
    "jsdom": "^29.1.1",
    "server-only": "^0.0.1",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "ws": "^8.21.0"
  },
  "overrides": {
    "exceljs": {
      "uuid": "11.1.1"
    }
  }
